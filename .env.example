# =============================================================================
# Meta Ads MCP Server — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control.
# =============================================================================

# ── Required ─────────────────────────────────────────────────────────────────
# Your Meta (Facebook) access token. Obtain via OAuth or from the Meta
# Business Suite → Settings → Advanced → Graph API Explorer.
META_ACCESS_TOKEN=

# ── Optional (needed for OAuth flows & token debug) ──────────────────────────
# Find these in Meta for Developers → Your App → Settings → Basic.
META_APP_ID=
META_APP_SECRET=

# OAuth redirect URI — must match the one registered in your Meta app.
# Default: https://localhost:3000/callback
META_REDIRECT_URI=https://localhost:3000/callback
